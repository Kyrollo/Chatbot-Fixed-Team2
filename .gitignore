# ─── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
*.egg

# ─── Virtual environments ─────────────────────────────────────────────────────
.venv/
venv/
env/

# ─── Environment & secrets ────────────────────────────────────────────────────
.env
*.ini

# ─── IDE / editor ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.code-workspace
*.swp
*.swo
*~

# ─── OS files ─────────────────────────────────────────────────────────────────
Thumbs.db
.DS_Store
desktop.ini

# ─── Data (auto-created at runtime) ──────────────────────────────────────────
data/
uploads/

# ─── Tools (auto-downloaded infra binaries — Redis, Keycloak) ────────────────
tools/

# ─── Infra (large binary archives — Redis/Keycloak zips and extracts) ────────
infra/

# ─── Test fixtures (auto-generated by test scripts) ──────────────────────────
scripts/fixtures/

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log

# ─── Gemini agent workspace ──────────────────────────────────────────────────
.gemini/