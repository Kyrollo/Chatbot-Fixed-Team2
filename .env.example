# =============================================================================
# RAG System — Environment Template
# Copy this file to .env and fill in your values.
# The .env file is used by ALL services via docker-compose env_file.
# NEVER commit .env — it is in .gitignore.
# =============================================================================

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres          # CHANGE in production
POSTGRES_DB=domain_db
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/domain_db
SYNC_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/domain_db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Qdrant ───────────────────────────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333

# ─── Keycloak ─────────────────────────────────────────────────────────────────
# Comma-separated list — services try each issuer in order
KEYCLOAK_ISSUER=http://keycloak:8080/realms/rag-system,http://localhost:8180/realms/rag-system
KEYCLOAK_REALM_URL=http://keycloak:8080/realms/rag-system
KEYCLOAK_CLIENT_ID=domain-service
KEYCLOAK_ALGORITHM=RS256
# Optional: paste realm public key body (base64) to skip HTTP fetch on startup
# Get from: Keycloak Admin → Realm Settings → Keys → RS256 → Public Key
KEYCLOAK_PUBLIC_KEY=

# ─── Internal service-to-service auth ─────────────────────────────────────────
# Shared secret header (X-Internal-Key) for /internal/* endpoints
# CHANGE this to a long random string in production
INTERNAL_API_KEY=rag-internal-dev-key-change-in-prod

# ─── Domain Service ───────────────────────────────────────────────────────────
DOMAIN_SERVICE_URL=http://domain-service:8001
SYSTEM_ADMIN_ROLE=system_admin
DEFAULT_LLM_ROUTE=api              # "api" = Groq first, "local" = Ollama only
DEFAULT_CHUNK_SIZE=512
DEFAULT_CHUNK_OVERLAP=64
DEFAULT_CONFIDENCE_THRESHOLD=0.5

# ─── Ingestion Service ────────────────────────────────────────────────────────
UPLOAD_DIR=/data/uploads
MAX_SIZE_MB=50

# ─── Retrieval Service ────────────────────────────────────────────────────────
RETRIEVAL_SERVICE_URL=http://retrieval-service:8003
TOP_K_RETRIEVE=20                  # candidates fetched before re-ranking
TOP_K_RERANK=5                     # final chunks passed to LLM
CACHE_TTL_SECONDS=3600             # semantic cache TTL (seconds)

# ─── LLM: Ollama (local, on-premises) ─────────────────────────────────────────
# Ollama runs inside Docker. Pull the model after first startup:
#   docker exec ollama ollama pull llama3.2:3b
OLLAMA_BASE_URL=http://ollama:11434/v1
OLLAMA_MODEL=llama3.2:3b

# ─── LLM: Groq API (cloud, fast — primary) ────────────────────────────────────
# Get your free API key at: https://console.groq.com
# Leave GROQ_API_KEY blank to disable Groq — falls back to Ollama automatically
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_API_KEY=gsk_YOUR_GROQ_KEY_HERE
GROQ_MODEL=llama-3.3-70b-versatile
