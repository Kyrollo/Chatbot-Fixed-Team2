# =============================================================================
# RAG System — Environment Template
# Copy this file to .env and fill in your values.
# Used by run_services.py and all FastAPI services.
# NEVER commit .env — it is in .gitignore.
# =============================================================================

# ─── PostgreSQL (local install required) ──────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=55555
POSTGRES_DB=domain_db
DATABASE_URL=postgresql+asyncpg://postgres:55555@localhost:5432/domain_db
SYNC_DATABASE_URL=postgresql://postgres:55555@localhost:5432/domain_db

# ─── Redis (optional — memory cache + sync ingestion used if unavailable) ─────
REDIS_URL=redis://localhost:6379/0

# ─── Qdrant (embedded local storage — no server needed) ───────────────────────
QDRANT_PATH=data/qdrant

# ─── Keycloak (started by run_services.py on port 8080) ───────────────────────
KEYCLOAK_ISSUER=http://localhost:8080/realms/rag-system
KEYCLOAK_REALM_URL=http://localhost:8080/realms/rag-system
KEYCLOAK_CLIENT_ID=domain-service
KEYCLOAK_ALGORITHM=RS256
KEYCLOAK_PUBLIC_KEY=

# ─── Internal service-to-service auth ─────────────────────────────────────────
INTERNAL_API_KEY=rag-internal-dev-key-change-in-prod

# ─── Service URLs (localhost API ports) ─────────────────────────────────────────
DOMAIN_SERVICE_URL=http://localhost:8001
INGESTION_SERVICE_URL=http://localhost:8002
RETRIEVAL_SERVICE_URL=http://localhost:8003
GENERATION_SERVICE_URL=http://localhost:8004
EVALUATION_SERVICE_URL=http://localhost:8005
UPLOAD_DIR=data/uploads

# ─── Domain defaults ────────────────────────────────────────────────────────────
SYSTEM_ADMIN_ROLE=system_admin
DEFAULT_LLM_ROUTE=api
DEFAULT_CHUNK_SIZE=512
DEFAULT_CHUNK_OVERLAP=64
DEFAULT_CONFIDENCE_THRESHOLD=0.5
MAX_SIZE_MB=50

# ─── Retrieval ────────────────────────────────────────────────────────────────
TOP_K_RETRIEVE=20
TOP_K_RERANK=5
CACHE_TTL_SECONDS=3600
RERANKER_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1

# ─── LLM: Ollama (optional local fallback) ─────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2:3b

# ─── LLM: Groq API (cloud, fast) ──────────────────────────────────────────────
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_API_KEY=************
GROQ_MODEL=llama-3.3-70b-versatile

# ─── Performance (limit BLAS threads) ─────────────────────────────────────────
OPENBLAS_NUM_THREADS=1
OMP_NUM_THREADS=1
MKL_NUM_THREADS=1
NUMEXPR_NUM_THREADS=1
