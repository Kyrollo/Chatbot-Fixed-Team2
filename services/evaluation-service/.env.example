# evaluation-service/.env.example
# Copy this file to evaluation-service/.env and fill in the values below.
#   copy .env.example .env        (Windows PowerShell)
#
# This service can also pick up DATABASE_URL / SYNC_DATABASE_URL /
# GROQ_API_KEY from your PROJECT'S ROOT .env if you export those values
# into the same shell before starting this service — but it is simplest,
# and recommended while you are testing the evaluation pipeline on its
# own, to keep a complete copy of everything it needs right here.

# ── LLM provider ──────────────────────────────────────────────────────────
# Leave GROQ_API_KEY empty to use the Ollama fallback instead.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Only used when GROQ_API_KEY is empty above.
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2:3b

# ── Redis (Celery broker + result backend) ─────────────────────────────────
# Same Redis instance the rest of the project (worker-service) already
# uses — Celery Beat just adds a new queue ("evaluation") on top of it.
REDIS_URL=redis://localhost:6379/0

# ── Database ─────────────────────────────────────────────────────────────
# Must point at the SAME Postgres database the rest of the project uses
# (domain_db), since this service reads from rag_query_logs, which is
# written by generation-service.
SYNC_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/domain_db

# ── Evaluation pipeline tuning (all have sane defaults) ────────────────────
EVAL_SCHEDULE_MINUTES=30      # how often Beat fires the batch job
EVAL_LOOKBACK_MINUTES=35      # FIRST-RUN-ONLY safety window (see db/queries.py) — ignored once the cursor exists
EVAL_SAMPLE_RATE=0.05         # fraction of eligible rows to evaluate (5%)
MODERATION_THRESHOLD=0.6      # score below this -> moderation queue
LIVE_CACHE_TTL_HOURS=168      # how long cached retrieved-context rows are kept before pruning (7 days)

# ── RAGAS — uses the same Groq key above, no separate credential needed ────
RAGAS_JUDGE_MODEL=groq/llama-3.3-70b-versatile
RAGAS_EMBEDDING_MODEL=intfloat/multilingual-e5-small
