# ── RAG System UI Environment ───────────────────────────────────────────────
# Copy this to .env and fill in values for your environment.

# Set to "true" to bypass Keycloak and use a mock dev user (never in production)
VITE_MOCK_AUTH=false

# Keycloak settings — must match the realm-export.json in services/auth/
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=rag-system
VITE_KEYCLOAK_CLIENT=rag-ui
